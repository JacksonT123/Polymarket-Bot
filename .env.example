# ─── Database ───────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon.tech, local, or any Postgres)
# Example Neon:  postgresql+asyncpg://user:pass@ep-xyz.us-east-1.aws.neon.tech/polymarket_bot?sslmode=require
# Example local: postgresql+asyncpg://postgres:password@localhost:5432/polymarket_bot
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/polymarket_bot

# ─── Trading Mode ───────────────────────────────────────────────────────────
# PAPER or LIVE
TRADING_MODE=PAPER

# ─── Live Mode Credentials (leave blank in paper mode) ──────────────────────
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PROXY_ADDRESS=

# ─── Notifications (all optional — bot logs to console if not set) ──────────
DISCORD_WEBHOOK_URL=
NTFY_TOPIC=

# ─── External Data Sources (optional) ───────────────────────────────────────
POLYTRACK_API_KEY=
POLYSIGHTS_API_KEY=

# ─── Dashboard ──────────────────────────────────────────────────────────────
DASHBOARD_PORT=8000
# Set these to enable basic auth if exposing beyond localhost:
DASHBOARD_USER=
DASHBOARD_PASS=

# ─── Emergency Kill Switch ──────────────────────────────────────────────────
# Set KILLSWITCH=1 to halt all new orders within 30s
KILLSWITCH=0

# ─── Tier Override (optional) ───────────────────────────────────────────────
# Set to 0-9 to cap automatic tier promotion. Leave blank for auto.
TIER_OVERRIDE=
