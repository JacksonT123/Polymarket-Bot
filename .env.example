# PAPER or LIVE — same execution path; only credentials differ
BOT_MODE=PAPER
DATABASE_PATH=bot.db
SSL_VERIFY=false

DATA_API_BASE_URL=https://data-api.polymarket.com
CLOB_BASE_URL=https://clob.polymarket.com

AUTO_DISCOVER_LEADERS=true
TRACKED_WALLETS=
ROSTER_ACTIVE_SIZE=15
ROSTER_STANDBY_SIZE=30
DISCOVERY_INTERVAL_HOURS=6
DISCOVERY_LEADERBOARD_LIMIT=100

# Rate-safe polling (do not lower without hitting 429s)
ACTIVITY_POLL_SECONDS=6
ACTIVITY_CONCURRENCY=1
DATA_API_MIN_INTERVAL_MS=450
CLOB_MIN_INTERVAL_MS=200

BANKROLL_CACHE_SECONDS=600
CONFLICT_WINDOW_SECONDS=60

STARTING_BANKROLL_USD=100
MIN_COPY_USD=1
MIN_COPY_USD_LIVE=2
MAX_COPY_PCT_PER_TRADE=0.05
MAX_LEADER_FRACTION_PER_TRADE=0.25
MAX_COPY_PCT_PER_MARKET=0.20
MAX_OPEN_MARKETS=8
ORDER_TYPE=FAK
PAPER_SLIPPAGE_CENTS=0.2
PAPER_DEPTH_HAIRCUT=0.25

KILL_SWITCH_ENABLED=false
KILL_SWITCH_DAILY_LOSS_USD=40

API_HOST=127.0.0.1
API_PORT=8788

POLYGON_PRIVATE_KEY=
POLYMARKET_PROXY_ADDRESS=
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=
SIGNATURE_TYPE=1
CHAIN_ID=137

CHAIN_LISTENER_ENABLED=false
POLYGON_RPC_URL=
